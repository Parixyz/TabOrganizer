{
  "manifest_version": 3,
  "name": "TabOrganizer",
  "description": "Manage tabs with pink project grouping, sorting, and layouts.",
  "version": "1.0.0",
  "permissions": ["tabs", "storage"],
  "host_permissions": ["<all_urls>"],

  "background": {
    "service_worker": "background.js"
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_popup": "popup.html",
    "default_title": "TabOrganizer",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },

  "options_page": "manager.html"
}